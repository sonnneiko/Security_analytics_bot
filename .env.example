# Telegram bot token из @BotFather (для @UnitSecurity_analytics_bot)
BOT_TOKEN=

# Сотрудники СБ — те, по кому собирается статистика и у кого есть доступ к командам
INITIAL_SB_USERS=[{"telegram_id":6300594719,"name":"Ани Тоноян"},{"telegram_id":7924502831,"name":"Светлана Григорьева"}]

# Админы/тестеры — доступ есть, но статистика по ним НЕ собирается.
# 6335871839 = Соня (владелец/тестер)
BOT_ADMINS=[6335871839]

# HTTP server для Teamly webhook (по умолчанию 8080)
SERVER_PORT=8080

# Teamly External API (доступ на тарифе Business/Enterprise).
# Все TEAMLY_* опциональны: без них Teamly-источник просто отключён.
TEAMLY_SLUG=
TEAMLY_CLIENT_ID=
TEAMLY_CLIENT_SECRET=
TEAMLY_REDIRECT_URI=
# Одноразовый код авторизации — нужен только на ПЕРВЫЙ запуск.
# После того как в YDB сохранятся access/refresh токены, переменную можно удалить.
TEAMLY_AUTH_CODE=
# Случайная строка ≥32 символов — попадает в URL webhook'a (/teamly/webhook/<secret>).
# Сгенерировать: openssl rand -hex 32
TEAMLY_WEBHOOK_SECRET=

# Bearer-токен приватного GET /internal/trigger-stats (число командных уникальных
# триггеров по ISO-неделям). Тянет локальный дашборд по localhost.
# Не задан → маршрут не регистрируется. Сгенерировать: openssl rand -hex 32
BOT_STATS_TOKEN=

# YDB (Yandex Cloud Serverless)
YDB_ENDPOINT=grpcs://ydb.serverless.yandexcloud.net:2135
YDB_DATABASE=/ru-central1/<cloud-id>/<db-id>
YDB_SA_KEY_FILE=./secrets/ydb-sa-key.json

# Optional
LOG_LEVEL=info

{
  "name": "security-analytics-bot",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "tsx watch src/main.ts",
    "start": "tsx src/main.ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "format": "prettier --write 'src/**/*.ts' 'tests/**/*.ts'"
  },
  "dependencies": {
    "@hono/node-server": "^2.0.4",
    "dotenv": "^16.4.5",
    "exceljs": "^4.4.0",
    "grammy": "^1.30.0",
    "hono": "^4.12.23",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "valibot": "^1.4.1",
    "ydb-sdk": "^5.11.1"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "prettier": "^3.8.3",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vitest": "^4.1.7"
  }
}
